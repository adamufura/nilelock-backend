PORT=4000
NODE_ENV=development

# MongoDB Atlas SRV
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB_NAME=nilelock

# Access token signing (min 16 chars). Refresh flow uses hashed tokens in DB; keep a strong secret for future use.
JWT_ACCESS_SECRET=replace-with-random-hex-64-chars
JWT_REFRESH_SECRET=replace-with-another-random-hex-64-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_DAYS=14

# Creates admin@nilelock.com and fahad@nilelock.com on first boot if missing (min 8 chars)
SEED_ADMIN_PASSWORD=nilelock

# Comma-separated, no spaces (or trim in code). Admin + simulator + Expo as needed.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
